{
  "manifest_version": 3,
  "name": "Resume Tailor + AutoFill",
  "description": "Tailor resume from JD and autofill job forms with predefined + AI answers.",
  "version": "1.0.0",
  "icons": {
    "16": "assets/icon16.png",
    "32": "assets/icon32.png",
    "48": "assets/icon48.png",
    "128": "assets/icon128.png"
  },
  "action": {
    "default_title": "Resume Tailor",
    "default_icon": {
      "16": "assets/icon16.png",
      "32": "assets/icon32.png"
    }
  },
  "side_panel": {
    "default_path": "popup.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "permissions": ["activeTab", "storage", "tabs", "sidePanel"],
  "web_accessible_resources": [
    {
      "resources": ["popup.html", "popup.css", "popup.js", "assets/*"],
      "matches": ["<all_urls>"]
    }
  ],
  "host_permissions": [
    "http://127.0.0.1:8000/*",
    "http://localhost:8000/*",
    "<all_urls>"
  ],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
